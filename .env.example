# Redis (for BullMQ queues)
REDIS_URL="redis://default:password@localhost:6379"

# AWS S3 / Cloudflare R2 (for file storage)
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="codebuff-artifacts"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
